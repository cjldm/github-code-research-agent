# DeepSeek Chat — required. Get one at https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_key_here

# Optional but recommended. Significantly higher GitHub API rate limits.
# Create at: GitHub Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=your_github_token_here

# Model configuration
CHAT_MODEL_PROVIDER=deepseek
SEARCH_MODEL=deepseek-chat
SCREEN_MODEL=deepseek-chat
ANALYSIS_MODEL=deepseek-chat

# Embeddings: "local_hash" (default, no API cost) or "openai"
EMBEDDING_PROVIDER=local_hash
EMBEDDING_MODEL=local-hash-1024

# FAISS vector index cache path (defaults to ~/.github_code_agent_cache/indexes)
# AGENT_INDEX_DIR=~/.github_code_agent_cache/indexes

# Repository download method: "zip" (default) or "git"
REPO_DOWNLOAD_METHOD=zip

# GitHub search backend: "api" (default), "mcp", or "auto"
GITHUB_SEARCH_BACKEND=api

# — MCP Server (optional) —
# Only needed if GITHUB_SEARCH_BACKEND=mcp or auto
# Requires Docker: https://docs.docker.com/get-docker/
GITHUB_MCP_ENABLED=0
GITHUB_MCP_COMMAND=docker
GITHUB_MCP_ARGS=["run","-i","--rm","-e","GITHUB_PERSONAL_ACCESS_TOKEN","ghcr.io/github/github-mcp-server","stdio","--toolsets","repos","--read-only","--log-file","/tmp/github-mcp.log"]
GITHUB_TOOLSETS=repos
GITHUB_READ_ONLY=1
